  "description": "Agentic iOS QA runner for Codex, GitHub Actions, and Bitrise",
  "type": "module",
  "license": "MIT",
  "author": "Mahmoud Ashraf",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahmoudashraf93/CodexPilot-iOS.git"
  },
  "homepage": "https://github.com/mahmoudashraf93/CodexPilot-iOS#readme",
  "bugs": {
    "url": "https://github.com/mahmoudashraf93/CodexPilot-iOS/issues"
  },
